#!/usr/bin/env bash
# kosha-discovery — pre-commit hook
# Prevents committing secrets, env files, and credential-bearing configs.
# Install: cp hooks/pre-commit .git/hooks/pre-commit  (or run: npm run prepare)
set -euo pipefail

RED='\033[0;31m'
YELLOW='\033[0;33m'
NC='\033[0m' # No Color

BLOCKED=0

# ── 1. Forbidden file patterns ──────────────────────────────────────────────
# These must NEVER be committed, regardless of .gitignore state (handles -f).
FORBIDDEN_PATTERNS=(
    '\.env$'
    '\.env\.'
    '\.pem$'
    '\.key$'
    '\.p12$'
    '\.pfx$'
    '\.jks$'
    '\.keystore$'
    'credentials\.json$'
    'service[-_]account.*\.json$'
    'gcloud.*credentials.*\.json$'
    '\.npmrc$'
    '\.pypirc$'
)

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR 2>/dev/null || true)

if [ -z "$STAGED_FILES" ]; then
    exit 0
fi

for pattern in "${FORBIDDEN_PATTERNS[@]}"; do
    matches=$(echo "$STAGED_FILES" | grep -iE "$pattern" || true)
    if [ -n "$matches" ]; then
        echo -e "${RED}BLOCKED:${NC} Forbidden file(s) staged for commit:"
        echo "$matches" | while read -r f; do
            echo -e "  ${RED}✗${NC} $f"
        done
        BLOCKED=1
    fi
done

# ── 2. Credential / secret patterns in file contents ────────────────────────
# Scan the staged diff (not working tree) for leaked secrets.
CREDENTIAL_PATTERNS=(
    # Provider API keys
    'sk-[A-Za-z0-9]{20,}'                        # OpenAI
    'sk-proj-[A-Za-z0-9]{20,}'                    # OpenAI project
    'AKIA[A-Z0-9]{16}'                            # AWS access key ID
    'ghp_[A-Za-z0-9]{36,}'                        # GitHub PAT
    'gho_[A-Za-z0-9]{36,}'                        # GitHub OAuth
    'ghs_[A-Za-z0-9]{36,}'                        # GitHub app
    'xoxb-[A-Za-z0-9-]{24,}'                      # Slack bot
    'xoxp-[A-Za-z0-9-]{24,}'                      # Slack user
    'AIza[A-Za-z0-9_-]{30,}'                      # Google API key
    'ya29\.[A-Za-z0-9_-]{50,}'                    # Google OAuth token
    'glpat-[A-Za-z0-9-]{20,}'                     # GitLab PAT
    'npm_[A-Za-z0-9]{36,}'                        # npm token
    'pypi-[A-Za-z0-9]{50,}'                       # PyPI token
    'hf_[A-Za-z0-9]{30,}'                         # Hugging Face token
    # Generic secrets
    'PRIVATE KEY-----'                             # PEM private keys
    'Bearer [A-Za-z0-9._-]{40,}'                  # Bearer tokens
    # AWS secret access key (40-char base64 following known env var patterns)
    'aws_secret_access_key\s*[=:]\s*[A-Za-z0-9/+=]{40}'
    'AWS_SECRET_ACCESS_KEY\s*[=:]\s*[A-Za-z0-9/+=]{40}'
)

# Only scan added/modified lines in the staged diff (lines starting with +)
STAGED_DIFF=$(git diff --cached --diff-filter=ACMR -U0 2>/dev/null || true)

for pattern in "${CREDENTIAL_PATTERNS[@]}"; do
    hits=$(echo "$STAGED_DIFF" | grep -nE "^\+.*$pattern" 2>/dev/null || true)
    if [ -n "$hits" ]; then
        echo -e "${RED}BLOCKED:${NC} Potential secret/credential detected in staged changes:"
        echo -e "  Pattern: ${YELLOW}${pattern}${NC}"
        echo "$hits" | head -3 | while read -r line; do
            # Truncate long lines to avoid dumping full keys
            truncated=$(echo "$line" | cut -c1-120)
            echo -e "  ${RED}✗${NC} $truncated"
        done
        count=$(echo "$hits" | wc -l | tr -d ' ')
        if [ "$count" -gt 3 ]; then
            echo -e "  ... and $((count - 3)) more"
        fi
        BLOCKED=1
    fi
done

# ── 3. Base64 blobs in config/data files ─────────────────────────────────────
# Scan JSON, YAML, TOML config files for suspiciously long base64 strings.
CONFIG_FILES=$(echo "$STAGED_FILES" | grep -iE '\.(json|ya?ml|toml|ini|cfg|conf)$' || true)

if [ -n "$CONFIG_FILES" ]; then
    echo "$CONFIG_FILES" | while IFS= read -r f; do
        [ -z "$f" ] && continue
        # Get staged content (not working tree) and look for base64 blobs (40+ chars)
        b64hits=$(git show ":$f" 2>/dev/null | grep -nE '[A-Za-z0-9+/]{40,}={0,2}' || true)
        if [ -n "$b64hits" ]; then
            echo -e "${RED}BLOCKED:${NC} Possible base64-encoded secret in config file:"
            echo -e "  File: ${YELLOW}${f}${NC}"
            echo "$b64hits" | head -3 | while IFS= read -r line; do
                truncated=$(echo "$line" | cut -c1-120)
                echo -e "  ${RED}✗${NC} $truncated"
            done
            # Signal to parent via temp file (subshell cannot set parent vars)
            touch "${TMPDIR:-/tmp}/.kosha-precommit-blocked"
        fi
    done
    # Pick up signal from subshell
    if [ -f "${TMPDIR:-/tmp}/.kosha-precommit-blocked" ]; then
        rm -f "${TMPDIR:-/tmp}/.kosha-precommit-blocked"
        BLOCKED=1
    fi
fi

# ── Verdict ──────────────────────────────────────────────────────────────────
if [ "$BLOCKED" -ne 0 ]; then
    echo ""
    echo -e "${RED}Commit aborted.${NC} Remove secrets before committing."
    echo "If this is a false positive, use: git commit --no-verify (with caution)"
    exit 1
fi

exit 0
